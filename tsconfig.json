{
	"compilerOptions": {
		"target": "es6",
		"module": "commonjs",
		"declaration": true,
		"allowJs": false,
		"noImplicitAny": false,
		"strict": true,
		"skipLibCheck": true,
		"outDir": "./lib",
		"allowSyntheticDefaultImports": true,
		"esModuleInterop": true
	},
	"include": ["src/*.ts", "types/*.ts", "docker/start.ts"]
}
