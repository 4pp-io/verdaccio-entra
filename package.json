{
	"name": "verdaccio-entra",
	"version": "1.0.0",
	"description": "Microsoft Entra ID (Azure AD) auth plugin for Verdaccio — validates access tokens via JWKS",
	"main": "lib/src/index.js",
	"types": "lib/src/index.d.ts",
	"engines": {
		"node": ">=18"
	},
	"dependencies": {
		"@verdaccio/core": "6.0.0-6-next.76",
		"debug": "4.4.3",
		"jsonwebtoken": "^9.0.3",
		"jwks-rsa": "^4.0.1"
	},
	"devDependencies": {
		"@changesets/changelog-github": "^0.6.0",
		"@changesets/cli": "^2.30.0",
		"@types/debug": "4.1.12",
		"@types/express": "4.17.25",
		"@types/jsonwebtoken": "9.0.10",
		"@types/node": "25.0.9",
		"@verdaccio/auth": "6.0.0-6-next.55",
		"@verdaccio/types": "11.0.0-6-next.25",
		"eslint": "^10.0.0",
		"typescript": "5.9.3",
		"typescript-eslint": "^8.57.0",
		"@vitest/coverage-v8": "^3.2.1",
		"tsx": "^4.21.0",
		"vitest": "^3.2.1"
	},
	"keywords": [
		"verdaccio",
		"verdaccio-plugin",
		"verdaccio-auth",
		"verdaccio-auth-plugin",
		"plugin",
		"auth",
		"authentication",
		"entra",
		"entra-id",
		"microsoft-entra",
		"azure-ad",
		"azure",
		"active-directory",
		"oidc",
		"oauth",
		"npm",
		"registry",
		"enterprise",
		"sso"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/4pp-io/verdaccio-entra.git"
	},
	"author": "primeinc <vincit.omnia.veritas@lellirose.com>",
	"scripts": {
		"build": "tsc",
		"lint": "eslint --max-warnings=0 --no-inline-config src/ types/",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:watch": "vitest",
		"check-config": "tsx scripts/check-config.ts",
		"changeset": "changeset",
		"version-packages": "changeset version && npm install",
		"release": "npm run build && changeset publish"
	}
}
