{
  "name": "@4pp-io/verdaccio-entra",
  "version": "0.2.0",
  "description": "Microsoft Entra ID (Azure AD) auth plugin for Verdaccio — validates access tokens via JWKS",
  "main": "lib/src/index.js",
  "types": "lib/src/index.d.ts",
  "bin": {
    "verdaccio-entra-check": "lib/src/cli.js"
  },
  "files": [
    "lib/",
    "!lib/src/__tests__/",
    "!lib/scripts/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@verdaccio/core": "6.0.0-6-next.76",
    "debug": "4.4.3",
    "jose": "^6.2.1",
    "valibot": "^1.3.0"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@types/debug": "4.1.12",
    "@types/node": "^25.5.0",
    "@verdaccio/types": "11.0.0-6-next.25",
    "@vitest/coverage-v8": "^4.1.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "10.1.8",
    "prettier": "3.8.1",
    "testcontainers": "^11.12.0",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.1.0"
  },
  "keywords": [
    "verdaccio",
    "verdaccio-plugin",
    "verdaccio-auth",
    "verdaccio-auth-plugin",
    "plugin",
    "auth",
    "authentication",
    "entra",
    "entra-id",
    "microsoft-entra",
    "azure-ad",
    "azure",
    "active-directory",
    "oidc",
    "oauth",
    "npm",
    "registry",
    "enterprise",
    "sso"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/4pp-io/verdaccio-entra.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "author": "primeinc <vincit.omnia.veritas@lellirose.com>",
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "lint": "eslint --max-warnings=0 --no-inline-config src/ types/",
    "test": "vitest run --exclude src/__tests__/e2e.test.ts",
    "test:e2e": "vitest run src/__tests__/e2e.test.ts",
    "test:e2e:debug": "cross-env DEBUG='testcontainers*' vitest run src/__tests__/e2e.test.ts",
    "test:coverage": "vitest run --coverage --exclude src/__tests__/e2e.test.ts",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check-config": "npm run build && node lib/src/cli.js",
    "changeset": "changeset",
    "version-packages": "changeset version && npm install && npm run format",
    "release": "npm run build && changeset publish --provenance"
  }
}
